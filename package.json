{
  "name": "resume-ai",
  "version": "1.0.0",
  "description": "AI-powered resume builder built with Next.js, Prisma and Supabase.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:visual": "playwright test e2e/visual.test.ts --project=chromium",
    "test:accessibility": "vitest run src/**/*.test.{ts,tsx} --environment=jsdom",
    "test:accessibility:lighthouse": "node scripts/lighthouse.js",
    "test:storybook": "storybook dev -p 6006",
    "analyze": "ANALYZE=true next build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
