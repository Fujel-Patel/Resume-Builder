    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "ai": "^6.0.193",
    "clsx": "^2.1.1",
