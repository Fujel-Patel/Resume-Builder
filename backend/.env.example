# ---------------------------------------------------------
# Generic application settings
# ---------------------------------------------------------
APP_ENV=development                # Options: development | testing | production
PORT=8000                          # Port where the FastAPI server will listen

# ---------------------------------------------------------
# Secret keys & cryptographic material
# ---------------------------------------------------------
SECRET_KEY=super-secret-key-change-this
JWT_ACCESS_SECRET=access-token-secret-key
JWT_REFRESH_SECRET=refresh-token-secret-key
JWT_ACCESS_EXPIRE_MINUTES=15      # Access token lifetime in minutes
JWT_REFRESH_EXPIRE_DAYS=7         # Refresh token lifetime in days
ENCRYPTION_KEY=32bytehexstringorbase64==   # 256‑bit AES key (32 bytes)

# ---------------------------------------------------------
# Database configuration
# ---------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/generative_cv

# ---------------------------------------------------------
# CORS / client interaction
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://myfrontend.example.com
CLIENT_URL=https://myfrontend.example.com
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------
# Email provider configuration
# Options: smtp | resend | sendgrid | log (empty = auto-detect)
# ---------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM=your-email@gmail.com

# SMTP (used when EMAIL_PROVIDER=smtp)
# For Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Resend API (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# SendGrid API (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# ---------------------------------------------------------
# Email verification settings
# ---------------------------------------------------------
VERIFICATION_TOKEN_EXPIRE_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
RESEND_COOLDOWN_SECONDS=60
RESEND_MAX_PER_DAY=5
PENDING_ACCOUNT_EXPIRE_HOURS=48

# ---------------------------------------------------------
# Password requirements
# ---------------------------------------------------------
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_BYTES=72

# ---------------------------------------------------------
# Brute-force protection
# ---------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ---------------------------------------------------------
# Supabase configuration (optional storage / auth fallback)
# ---------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sgp....your-service-key
STORAGE_BUCKET=generative-cv-bucket

# ---------------------------------------------------------
# PDF export via Playwright
# ---------------------------------------------------------
PDF_EXPORT_TIMEOUT_MS=30000
