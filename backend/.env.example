# ---------------------------------------------------------
# Generic application settings
# ---------------------------------------------------------
APP_ENV=development                # Options: development | testing | production
PORT=8000                          # Port where the FastAPI server will listen

# ---------------------------------------------------------
# Secret keys & cryptographic material
# ---------------------------------------------------------
SECRET_KEY=super-secret-key-change-this
JWT_ACCESS_SECRET=access-token-secret-key
JWT_REFRESH_SECRET=refresh-token-secret-key
JWT_ACCESS_EXPIRE_MINUTES=15      # Access token lifetime in minutes
JWT_REFRESH_EXPIRE_DAYS=7         # Refresh token lifetime in days
ENCRYPTION_KEY=32bytehexstringorbase64==   # 256‑bit AES key (32 bytes)

# ---------------------------------------------------------
# Database configuration
# ---------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/generative_cv

# ---------------------------------------------------------
# CORS / client interaction
# ---------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://myfrontend.example.com
CLIENT_URL=https://myfrontend.example.com

# ---------------------------------------------------------
# Email / SMTP configuration (for account verification, etc.)
# ---------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@example.com

# ---------------------------------------------------------
# Supabase configuration (optional storage / auth fallback)
# ---------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sgp....your-service-key
STORAGE_BUCKET=generative-cv-bucket